// SCSJ4383 Software Construction - Project 1 (Part A) - Jenkins Pipeline (Windows)
// Checkout -> Build -> Unit Test -> JMeter performance report -> Docker build & push.
// JMeter is downloaded automatically; Docker image uses your Docker Hub account.
pipeline {
    agent any
    tools {
        maven 'Maven3'
    }
    environment {
        DOCKER_IMAGE = 'wojtek0/scsj4383-devops-demo'
        DOCKER_TAG = "${env.BUILD_NUMBER}"
        PATH = "${env.JAVA_HOME}\\bin;${env.PATH}"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                dir('part-a-app') {
                    bat 'mvn -B -DskipTests clean package'
                }
            }
        }
        stage('Unit Test') {
            steps {
                dir('part-a-app') {
                    bat 'mvn -B test'
                }
            }
            post {
                always {
                    junit 'part-a-app/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Performance Test (JMeter)') {
            steps {
                dir('part-a-app') {
                    bat 'if not exist apache-jmeter\\bin\\jmeter.bat powershell -Command "Invoke-WebRequest -Uri https://archive.apache.org/dist/jmeter/binaries/apache-jmeter-5.6.3.zip -OutFile jmeter.zip; Expand-Archive jmeter.zip -DestinationPath . -Force; Rename-Item apache-jmeter-5.6.3 apache-jmeter"'
                    bat 'if exist jmeter-report rmdir /s /q jmeter-report'
                    bat 'if exist results.jtl del /q results.jtl'
                    bat 'start "DEMOAPP" /min cmd /c "java -jar target\\devops-demo.jar"'
                    bat 'ping -n 9 127.0.0.1 >nul'
                    bat 'apache-jmeter\\bin\\jmeter.bat -n -t jmeter\\test-plan.jmx -l results.jtl -e -o jmeter-report'
                    bat 'taskkill /FI "WINDOWTITLE eq DEMOAPP*" /T /F || exit 0'
                }
            }
            post {
                always {
                    perfReport sourceDataFiles: 'part-a-app/results.jtl'
                    archiveArtifacts artifacts: 'part-a-app/jmeter-report/**', allowEmptyArchive: true
                }
            }
        }
        stage('Docker Build and Push') {
            steps {
                dir('part-a-app') {
                    script {
                        docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-creds') {
                            def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                            image.push()
                            image.push('latest')
                        }
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline finished successfully. Docker image pushed to Docker Hub.'
        }
        failure {
            echo 'Pipeline failed - check the stage logs above.'
        }
    }
}
